# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Gemini AI (server-side only)
GEMINI_API_KEY=your-gemini-api-key

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET go in Supabase Edge Function secrets (not client-side)
# supabase secrets set STRIPE_SECRET_KEY=sk_test_... STRIPE_WEBHOOK_SECRET=whsec_...
# APP_URL=https://servicios-productos-online-ignasi.vercel.app

# Resend (transactional emails)
# RESEND_API_KEY=re_...

# Dev: set mock user role for local testing (default: client)
# VITE_MOCK_ROLE=admin
